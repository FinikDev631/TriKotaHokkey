rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {userId}
    // Fields:
    //   - uid: string (required) - Unique user ID
    //   - displayName: string (required) - User's display name
    //   - photoURL: string (optional) - User's profile picture URL
    //   - elo: integer (required) - Elo rating
    //   - wins: integer (required) - Number of wins
    //   - losses: integer (required) - Number of losses
    //   - lastCharacter: string (optional) - Last selected character
    //
    // Collection: matches
    // Document ID: {matchId}
    // Fields:
    //   - player1: string (required) - UID of player 1
    //   - player2: string (optional) - UID of player 2
    //   - player1Char: string (optional) - Character selected by player 1
    //   - player2Char: string (optional) - Character selected by player 2
    //   - player1Score: integer (optional) - Score of player 1
    //   - player2Score: integer (optional) - Score of player 2
    //   - status: string (required) - Current match status (waiting, playing, finished)
    //   - createdAt: timestamp (required) - Creation time
    //   - updatedAt: timestamp (optional) - Last update time
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          ((request.auth.token.email == "finiklts@gmail.com" || request.auth.token.email == "korkinsasha667@gmail.com") && request.auth.token.email_verified == true));
    }

    function isNotBanned() {
      return isAuthenticated() && 
        (!exists(/databases/$(database)/documents/users/$(request.auth.uid)) || 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('isBanned', false) == false);
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'displayName', 'elo', 'wins', 'losses']) &&
             data.uid is string &&
             data.displayName is string && data.displayName.size() < 100 &&
             data.elo is int &&
             data.wins is int &&
             data.losses is int &&
             (!('isBanned' in data) || data.isBanned is bool);
    }

    function isValidMatch(data) {
      return data.keys().hasAll(['player1', 'status', 'createdAt']) &&
             data.player1 is string &&
             data.status in ['waiting', 'playing', 'finished'];
    }

    match /users/{userId} {
      allow read: if isAuthenticated() && isNotBanned();
      allow create: if isOwner(userId) && isValidUser(request.resource.data) && request.resource.data.elo == 1000;
      allow update: if isNotBanned() && isValidUser(request.resource.data) && 
                    (isOwner(userId) || isAdmin());
    }

    match /matches/{matchId} {
      allow read: if isAuthenticated() && isNotBanned();
      allow create: if isNotBanned() && isValidMatch(request.resource.data) && request.resource.data.player1 == request.auth.uid;
      allow update: if isNotBanned() && isValidMatch(request.resource.data) &&
                    (request.auth.uid == resource.data.player1 || request.auth.uid == resource.data.player2 || isAdmin());
      allow delete: if isAdmin();
    }
    
    match /test/connection {
      allow read: if true;
    }
  }
}
